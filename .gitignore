# dependencies
node_modules/

# local database (the harness's system of record lives outside git)
*.db
*.db-journal
*.db-shm
*.db-wal

# secrets / env — root and nested (covers suno-api/.env)
.env
**/.env

# build output
.next/

# vendored third-party clone (gcui-art/suno-api) — has its own git history
suno-api/

# local generation artifacts (per-song screenshots, brief drafts)
gen-*.png

# personal song briefs stay local — only the template is tracked
briefs/*.json
!briefs/EXAMPLE.json

# one-off generation/spike screenshots
suno-*.png
cdp-smoke.png
